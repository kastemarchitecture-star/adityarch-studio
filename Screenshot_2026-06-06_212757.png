* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --color-gold: #C9A962;
  --color-gold-dark: #A68B3E;
  --color-charcoal: #2C2C2C;
  --color-charcoal-dark: #1A1A1A;
  --color-ivory: #FFFFF0;
  --color-light: #F5F5F0;
  --color-text-dark: #8B8680;
  --color-success: #25D366;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #FFFFFF;
  color: var(--color-charcoal);
  line-height: 1.6;
  overflow-x: hidden;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

@media (max-width: 768px) {
  .container {
    padding: 0 20px;
  }
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 600;
  line-height: 1.2;
  color: var(--color-charcoal);
}

h1 {
  font-size: clamp(32px, 5vw, 64px);
  letter-spacing: -0.5px;
}

h2 {
  font-size: clamp(28px, 4vw, 48px);
  margin-bottom: 24px;
}

h3 {
  font-size: clamp(20px, 3vw, 28px);
  margin-bottom: 16px;
}

h4 {
  font-size: 18px;
  font-weight: 600;
}

p {
  font-size: 16px;
  line-height: 1.7;
  color: var(--color-text-dark);
}

a {
  color: inherit;
  text-decoration: none;
  transition: color 0.3s ease;
}

/* Sections */
.section {
  padding: 80px 0;
}

.section.bg-white {
  background: #FFFFFF;
}

.section.bg-ivory {
  background: var(--color-ivory);
}

.section.bg-charcoal {
  background: var(--color-charcoal-dark);
}

@media (max-width: 768px) {
  .section {
    padding: 60px 0;
  }
}

/* Section Headers */
.section-header {
  text-align: center;
  margin-bottom: 48px;
}

.section-subtitle {
  display: inline-block;
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-weight: 500;
  font-style: italic;
  color: var(--color-gold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.gold-line {
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--color-gold), var(--color-gold-dark));
}

.gold-line-center {
  margin-left: auto;
  margin-right: auto;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 32px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border: none;
  border-radius: 0;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
}

.btn-gold {
  background: linear-gradient(135deg, var(--color-gold), var(--color-gold-dark));
  color: #FFFFFF;
}

.btn-gold:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(201, 169, 98, 0.3);
}

.btn-gold:active {
  transform: translateY(0);
}

.btn-secondary {
  background: transparent;
  border: 1px solid var(--color-charcoal);
  color: var(--color-charcoal);
}

.btn-secondary:hover {
  background: var(--color-charcoal);
  color: #FFFFFF;
}

.btn-gold-outline {
  background: transparent;
  border: 1px solid var(--color-gold);
  color: var(--color-gold);
}

.btn-gold-outline:hover {
  background: var(--color-gold);
  color: #FFFFFF;
}

.btn-lg {
  padding: 18px 48px;
  font-size: 14px;
}

@media (max-width: 768px) {
  .btn {
    width: 100%;
    justify-content: center;
  }
}

/* Header Navigation */
header {
  font-family: 'Cormorant Garamond', serif;
}

header a {
  transition: color 0.3s ease;
}

header a:hover {
  color: var(--color-gold);
}

.desktop-nav {
  display: flex;
  align-items: center;
  gap: 40px;
}

.mobile-menu-btn {
  background: none;
  border: none;
  cursor: pointer;
  display: none;
  padding: 8px;
}

@media (max-width: 1024px) {
  .desktop-nav {
    display: none !important;
  }

  .mobile-menu-btn {
    display: block !important;
  }
}

/* Utilities */
.text-center {
  text-align: center;
}

.mt-24 {
  margin-top: 24px;
}

.mt-32 {
  margin-top: 32px;
}

.mb-24 {
  margin-bottom: 24px;
}

.mb-32 {
  margin-bottom: 32px;
}

/* Smooth Scrolling */
@media (prefers-reduced-motion: no-preference) {
  html {
    scroll-behavior: smooth;
  }
}

/* Print Styles */
@media print {
  body {
    background: white;
  }

  .btn, header, footer {
    display: none;
  }
}

/* Dark Mode Support (future) */
@media (prefers-color-scheme: dark) {
  body {
    background: var(--color-charcoal-dark);
    color: #FFFFFF;
  }

  p {
    color: #CCCCCC;
  }

  h1, h2, h3, h4, h5, h6 {
    color: #FFFFFF;
  }
}
