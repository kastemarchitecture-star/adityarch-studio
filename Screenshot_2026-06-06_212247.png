import { useEffect, useState } from 'react';
import { motion, useScroll, useTransform, AnimatePresence, type Variants } from 'framer-motion';
import { Phone, Mail, MapPin, ChevronDown, X, ArrowRight, Check, Star, Building2, PenTool, Hammer, Sofa, Clock, Shield, Award, Hop as Home } from 'lucide-react';
import './index.css';

// Fade in animation variants
const fadeInUp: Variants = {
  hidden: { opacity: 0, y: 30 },
  visible: { opacity: 1, y: 0, transition: { duration: 0.6, ease: "easeOut" as const } }
};

const staggerContainer: Variants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: { staggerChildren: 0.1, delayChildren: 0.2 }
  }
};

// Header Component
function Header() {
  const [scrolled, setScrolled] = useState(false);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

  useEffect(() => {
    const handleScroll = () => setScrolled(window.scrollY > 50);
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const navLinks = [
    { href: '#portfolio', label: 'Portfolio' },
    { href: '#services', label: 'Layanan' },
    { href: '#benefits', label: 'Keunggulan' },
    { href: '#testimonials', label: 'Testimoni' },
    { href: '#contact', label: 'Kontak' },
  ];

  return (
    <motion.header
      initial={{ y: -100 }}
      animate={{ y: 0 }}
      transition={{ duration: 0.6 }}
      style={{
        position: 'fixed',
        top: 0,
        left: 0,
        right: 0,
        zIndex: 1000,
        background: scrolled ? 'rgba(255, 255, 255, 0.95)' : 'transparent',
        backdropFilter: scrolled ? 'blur(20px)' : 'none',
        borderBottom: scrolled ? '1px solid rgba(201, 169, 98, 0.1)' : 'none',
        transition: 'all 0.3s ease'
      }}
    >
      <div className="container" style={{
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'space-between',
        padding: scrolled ? '16px 32px' : '24px 32px',
        transition: 'padding 0.3s ease'
      }}>
        <a href="#" style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
          <div style={{
            width: '48px',
            height: '48px',
            background: 'linear-gradient(135deg, #2C2C2C, #1A1A1A)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            position: 'relative'
          }}>
            <span style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: '24px',
              fontWeight: 600,
              color: '#C9A962'
            }}>A</span>
          </div>
          <div style={{ display: 'flex', flexDirection: 'column' }}>
            <span style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: '18px',
              fontWeight: 600,
              color: scrolled ? '#2C2C2C' : '#FFFFFF',
              letterSpacing: '0.1em',
              textTransform: 'uppercase',
              lineHeight: 1.2
            }}>ADITYARCH</span>
            <span style={{
              fontSize: '9px',
              fontWeight: 500,
              color: scrolled ? '#C9A962' : 'rgba(255,255,255,0.8)',
              letterSpacing: '0.2em',
              textTransform: 'uppercase'
            }}>Studio & Build</span>
          </div>
        </a>

        <nav style={{
          display: 'flex',
          alignItems: 'center',
          gap: '40px'
        }} className="desktop-nav">
          {navLinks.map((link) => (
            <a
              key={link.href}
              href={link.href}
              style={{
                fontSize: '13px',
                fontWeight: 500,
                color: scrolled ? '#2C2C2C' : '#FFFFFF',
                letterSpacing: '0.05em',
                textTransform: 'uppercase',
                position: 'relative',
                paddingBottom: '4px'
              }}
              onMouseEnter={(e) => {
                e.currentTarget.style.color = '#C9A962';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.color = scrolled ? '#2C2C2C' : '#FFFFFF';
              }}
            >
              {link.label}
            </a>
          ))}
          <a
            href="https://wa.me/6282147777570"
            target="_blank"
            rel="noopener noreferrer"
            className="btn btn-gold"
            style={{
              padding: '12px 24px',
              fontSize: '11px'
            }}
          >
            Konsultasi Gratis
          </a>
        </nav>

        <button
          onClick={() => setMobileMenuOpen(true)}
          style={{
            display: 'none',
            color: scrolled ? '#2C2C2C' : '#FFFFFF',
            padding: '8px'
          }}
          className="mobile-menu-btn"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>

      {/* Mobile Menu */}
      <AnimatePresence>
        {mobileMenuOpen && (
          <motion.div
            initial={{ opacity: 0, x: '100%' }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: '100%' }}
            style={{
              position: 'fixed',
              top: 0,
              right: 0,
              bottom: 0,
              width: '80%',
              maxWidth: '320px',
              background: '#FFFFFF',
              padding: '32px',
              zIndex: 2000,
              boxShadow: '-10px 0 40px rgba(0,0,0,0.1)'
            }}
          >
            <button
              onClick={() => setMobileMenuOpen(false)}
              style={{
                position: 'absolute',
                top: '24px',
                right: '24px',
                color: '#2C2C2C'
              }}
            >
              <X size={24} />
            </button>
            <div style={{ marginTop: '64px', display: 'flex', flexDirection: 'column', gap: '24px' }}>
              {navLinks.map((link) => (
                <a
                  key={link.href}
                  href={link.href}
                  onClick={() => setMobileMenuOpen(false)}
                  style={{
                    fontSize: '16px',
                    fontWeight: 500,
                    color: '#2C2C2C',
                    letterSpacing: '0.05em',
                    textTransform: 'uppercase'
                  }}
                >
                  {link.label}
                </a>
              ))}
              <a
                href="https://wa.me/6282147777570"
                target="_blank"
                rel="noopener noreferrer"
                className="btn btn-gold"
                style={{ marginTop: '16px' }}
              >
                Konsultasi Gratis
              </a>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <style>{`
        @media (max-width: 1024px) {
          .desktop-nav { display: none !important; }
          .mobile-menu-btn { display: block !important; }
        }
      `}</style>
    </motion.header>
  );
}

// Hero Section
function Hero() {
  const { scrollY } = useScroll();
  const y = useTransform(scrollY, [0, 500], [0, 150]);
  const opacity = useTransform(scrollY, [0, 300], [1, 0]);

  return (
    <section style={{
      position: 'relative',
      minHeight: '100vh',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'center',
      overflow: 'hidden'
    }}>
      {/* Video Background Placeholder */}
      <motion.div
        style={{ y }}
        className="hero-bg"
        dangerouslySetInnerHTML={{
          __html: `
          <video
            autoplay
            muted
            loop
            playsinline
            style={{
              position: 'absolute',
              top: '50%',
              left: '50%',
              minWidth: '100%',
              minHeight: '100%',
              width: 'auto',
              height: 'auto',
              transform: 'translate(-50%, -50%)',
              objectFit: 'cover',
              zIndex: -2
            }}
          >
            <source src="https://assets.mixkit.co/videos/preview/mixkit-luxury-house-with-pool-4642-large.mp4" type="video/mp4" />
          </video>
        `}}
      />

      {/* Fallback Background Image */}
      <div style={{
        position: 'absolute',
        inset: 0,
        backgroundImage: `url('https://images.pexels.com/photos/2102587/pexels-photo-2102587.jpeg?auto=compress&cs=tinysrgb&w=1920')`,
        backgroundSize: 'cover',
        backgroundPosition: 'center',
        filter: 'brightness(0.4)',
        zIndex: -1
      }} />

      {/* Gradient Overlays */}
      <div style={{
        position: 'absolute',
        inset: 0,
        background: 'linear-gradient(180deg, rgba(26,26,26,0.4) 0%, transparent 40%, transparent 60%, rgba(26,26,26,0.8) 100%)',
        zIndex: 0
      }} />

      {/* Content */}
      <motion.div
        style={{ opacity }}
        className="container"
        role="main"
      >
        <motion.div
          initial={{ opacity: 0, y: 40 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 1, delay: 0.3 }}
          style={{
            textAlign: 'center',
            maxWidth: '1000px',
            margin: '0 auto',
            position: 'relative',
            zIndex: 1
          }}
        >
          <motion.p
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.5 }}
            style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: 'clamp(14px, 2vw, 16px)',
              fontWeight: 400,
              fontStyle: 'italic',
              color: '#C9A962',
              letterSpacing: '0.1em',
              marginBottom: '24px'
            }}
          >
            "Designing Timeless Luxury, Building Your Legacy"
          </motion.p>

          <motion.h1
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.7 }}
            style={{
              color: '#FFFFFF',
              marginBottom: '32px',
              lineHeight: 1.15
            }}
          >
            Desain Rumah Mewah Modern Classic Eropa dengan Nilai Investasi Premium
          </motion.h1>

          <motion.p
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.9 }}
            style={{
              fontSize: 'clamp(16px, 2vw, 20px)',
              color: 'rgba(255,255,255,0.85)',
              maxWidth: '800px',
              margin: '0 auto 24px',
              lineHeight: 1.8
            }}
          >
            Wujudkan rumah impian bergaya Eropa dengan apresiasi nilai 12-28% per tahun. ADITYARCH menghadirkan solusi design, build & interior terintegrasi untuk investasi property premium di Balikpapan dan Kalimantan Timur.
          </motion.p>

          <motion.p
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 1.0 }}
            style={{
              fontSize: 'clamp(14px, 1.5vw, 18px)',
              color: 'rgba(255,255,255,0.7)',
              maxWidth: '700px',
              margin: '0 auto 48px',
              lineHeight: 1.7
            }}
          >
            Spesialisasi: European Modern Classic Homes • Resort Development • Investment-Grade Properties. Dari konsep awal hingga finishing premium dalam satu manajemen profesional.
          </motion.p>

          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 1.2 }}
            style={{
              display: 'flex',
              flexWrap: 'wrap',
              gap: '16px',
              justifyContent: 'center',
              alignItems: 'center'
            }}
          >
            <a href="https://wa.me/6282147777570" target="_blank" rel="noopener noreferrer" className="btn btn-gold btn-lg">
              Konsultasi Gratis
              <ArrowRight size={18} />
            </a>
            <a href="https://wa.me/6282147777570?text=Halo,%20saya%20ingin%20jadwal%20survey%20gratis" target="_blank" rel="noopener noreferrer" className="btn btn-secondary btn-lg" style={{ color: '#FFFFFF', borderColor: 'rgba(255,255,255,0.5)' }}>
              Jadwalkan Survey Gratis
            </a>
            <a href="#portfolio" className="btn btn-secondary btn-lg" style={{ color: '#FFFFFF', borderColor: 'rgba(255,255,255,0.5)' }}>
              Lihat Portfolio
            </a>
          </motion.div>
        </motion.div>
      </motion.div>

      {/* Scroll Indicator */}
      <motion.div
        animate={{ y: [0, 10, 0] }}
        transition={{ duration: 2, repeat: Infinity }}
        style={{
          position: 'absolute',
          bottom: '40px',
          left: '50%',
          transform: 'translateX(-50%)',
          color: '#FFFFFF',
          opacity: 0.6,
          zIndex: 1
        }}
      >
        <ChevronDown size={32} />
      </motion.div>
    </section>
  );
}

// Why Choose Us Section
function WhyChooseUs() {
  const reasons = [
    {
      icon: <Home size={32} />,
      title: 'Design Modern Classic Specialist',
      description: 'Menghadirkan desain yang sedang menjadi tren dan memiliki nilai investasi tinggi.'
    },
    {
      icon: <Building2 size={32} />,
      title: 'One Stop Solution',
      description: 'Design, Konstruksi, Interior, Furniture dalam satu manajemen terintegrasi.'
    },
    {
      icon: <Award size={32} />,
      title: 'Pengalaman Jawa & Bali',
      description: 'Membawa kualitas desain dan pengerjaan premium ke Kalimantan Timur.'
    },
    {
      icon: <Phone size={32} />,
      title: 'Free Consultation',
      description: 'Konsultasi dan survey GRATIS untuk area Balikpapan.'
    },
    {
      icon: <Shield size={32} />,
      title: 'Transparan',
      description: 'Progress report berkala dan pengawasan ketat setiap tahap proyek.'
    },
    {
      icon: <Clock size={32} />,
      title: 'Tepat Waktu',
      description: 'Manajemen proyek profesional dan terukur dengan timeline yang jelas.'
    }
  ];

  return (
    <section id="why-us" className="section bg-ivory">
      <div className="container">
        <motion.div
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, margin: "-100px" }}
          variants={staggerContainer}
          className="section-header"
        >
          <motion.span variants={fadeInUp} className="section-subtitle">Mengapa Memilih Kami</motion.span>
          <motion.h2 variants={fadeInUp}>Keunggulan ADITYARCH</motion.h2>
          <motion.div variants={fadeInUp} className="gold-line gold-line-center" style={{ marginTop: '24px' }} />
        </motion.div>

        <motion.div
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, margin: "-50px" }}
          variants={staggerContainer}
          style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(auto-fit, minmax(320px, 1fr))',
            gap: '32px'
          }}
        >
          {reasons.map((reason, index) => (
            <motion.div
              key={index}
              variants={fadeInUp}
              whileHover={{ y: -8, transition: { duration: 0.3 } }}
              style={{
                background: '#FFFFFF',
                padding: '40px 32px',
                position: 'relative',
                overflow: 'hidden'
              }}
            >
              <div style={{
                position: 'absolute',
                top: 0,
                left: 0,
                width: '4px',
                height: '100%',
                background: 'linear-gradient(180deg, #C9A962, #D4BD7A)'
              }} />

              <div style={{
                width: '64px',
                height: '64px',
                border: '1px solid rgba(201, 169, 98, 0.3)',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                marginBottom: '24px',
                color: '#C9A962'
              }}>
                {reason.icon}
              </div>

              <h4 style={{ marginBottom: '12px', color: '#2C2C2C' }}>{reason.title}</h4>
              <p style={{ color: '#8B8680', margin: 0 }}>{reason.description}</p>
            </motion.div>
          ))}
        </motion.div>
      </div>
    </section>
  );
}

